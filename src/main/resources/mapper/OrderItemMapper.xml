<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.swiftstock.mapper.OrderItemMapper">
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_item (
            order_id, product_id, product_name, quantity, price, amount, remark
        ) VALUES (
            #{orderId}, #{productId}, #{productName}, #{quantity}, #{price}, #{amount}, #{remark}
        )
    </insert>
    
    <select id="selectByOrderId" resultType="com.swiftstock.entity.OrderItem">
        SELECT * FROM order_item WHERE order_id = #{orderId}
    </select>
    
    <delete id="deleteByOrderId">
        DELETE FROM order_item WHERE order_id = #{orderId}
    </delete>
</mapper> 